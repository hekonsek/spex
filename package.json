{
  "name": "spex",
  "version": "0.30.0",
  "description": "AI-friendly projects specifications",
  "license": "MIT",
  "type": "module",
  "bin": {
    "spex": "dist/adapters/in/cli/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/adapters/in/cli/cli.js",
    "check": "tsc --noEmit",
    "test": "node --import tsx --test $(find test -name '*.test.ts' -print)",
    "start": "node dist/adapters/in/cli/cli.js",
    "dev": "npm run build && npm run start --",
    "install-latest": "npm install -g https://github.com/hekonsek/spex/releases/download/v${npm_package_version}/spex-${npm_package_version}.tgz"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "minimatch": "^10.2.2",
    "ora": "^9.3.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "jsonpath-plus": "^10.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
